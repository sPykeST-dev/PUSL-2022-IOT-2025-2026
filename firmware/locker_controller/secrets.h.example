// =============================================================
//  secrets.h.example
//  Copy this file to secrets.h and fill in your values.
//  secrets.h is listed in .gitignore — never commit it.
// =============================================================

#define WIFI_SSID     "your-wifi-network-name"
#define WIFI_PASSWORD "your-wifi-password"

// Your laptop's IP address on the shared WiFi network.
// Run: ipconfig getifaddr en0   (Mac, WiFi interface)
//      ipconfig getifaddr en1   (Mac, alternate interface)
//      ipconfig                 (Windows — look for the hotspot adapter)
// The ESP32 and the laptop running the backend MUST be on the same network.
// Do NOT use "localhost" — the ESP32 cannot reach it.
#define SERVER_URL    "http://192.168.x.x:8080"

// Locker identifier — must match the ID in the database (lockers table).
#define LOCKER_ID     "LOCKER-01"
